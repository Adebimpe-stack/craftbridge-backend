      });
    }

    invitation.status = "pending";
    invitation.expiresAt = new Date(
      Date.now() + 7 * 24 * 60 * 60 * 1000
    );

    await invitation.save();

console.log("RESENDING EMAIL TO:", invitation.email);


    res.json({
